//练习1-8 编写一个统计空格、制表符和换行符数量的程序
#include <stdio.h>
main(){
    int c,n1,n2,n3;
    n1 = n2 = n3 = 0;

    while ((c = getchar()) != EOF){
        if (c == ' ')
            ++n1;
        if (c == '\t')
            ++n2;
        if (c == '\n')
            ++n3;
    }
    printf("spaces: %d, tabs: %d, newlines: %d\n", n1, n2, n3);
}
