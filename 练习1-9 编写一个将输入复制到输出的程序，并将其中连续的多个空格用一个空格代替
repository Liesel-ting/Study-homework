//练习1-9 编写一个将输入复制到输出的程序，并将其中连续的多个空格用一个空格代替
#include <stdio.h>
#define NONBLANK 'a'               //任意非空白字符
main(){
    int c, lastc;

    lastc = NONBLANK;              //初始化为非空白字符
    while ((c = getchar()) != EOF){
        if (c != ' ')
            putchar(c);
            if (c == ' ')
                if (lastc != ' ')
                    putchar(c);
        
            lastc = c;
    }
}
