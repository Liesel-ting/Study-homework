//练习1-3 修改温度转换程序，使之能在转换表的顶部打印一个标题
#include <stdio.h>
main()
{
    float fahr, celsius;
    int lower,upper,step;

    lower = 0;     //温度的上限
    upper = 300;   //温度的下限
    step = 20;     //步长

    printf("Fahrenheit Celsius\n");
    fahr = lower;
    while (fahr <= upper){
        celsius = (5.0/9.0) * (fahr - 32.0);
        printf("%3.0f %6.1f\n", fahr, celsius );
        fahr = fahr + step;

    }

}
