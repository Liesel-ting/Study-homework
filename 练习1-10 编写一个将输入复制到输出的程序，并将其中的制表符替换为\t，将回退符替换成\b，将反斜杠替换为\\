//练习1-10 编写一个将输入复制到输出的程序，并将其中的制表符替换为\t，将回退符替换成\b，将反斜杠替换为\\
#include <stdio.h>
main()
{
    int c;

    while ((c = getchar()) != EOF){
        if (c == '\t')
            printf("\\t");
        if (c == '\b')
            printf("\\b");
        if (c == '\\')
            printf("\\\\");
        if(c != '\b')
            if(c!= '\t')
                if(c != '\\')
                    putchar(c);
    }
}
